PORT=3000
NODE_ENV=production
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
SUCCESS_URL=https://ai.estudiofocus.online/success.html
FAILURE_URL=https://ai.estudiofocus.online/
PENDING_URL=https://ai.estudiofocus.online/
WEBHOOK_URL=https://ai.estudiofocus.online/webhook

# UTMify recebe somente a notificação server-side da venda.
UTMIFY_TOKEN=
UTMIFY_IS_TEST=false

# Container GTM server-side provisionado na VPS.
GTM_SERVER_URL=https://sst.seu-dominio.com
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Opcional: diretório persistente para atribuição e idempotência.
# Em produção, monte este caminho em um volume persistente.
RUNTIME_DATA_DIR=.runtime

# Somente para depuracao temporaria do container Server no GTM.
# Remova ou deixe vazio depois dos testes.
GTM_SERVER_PREVIEW_HEADER=
